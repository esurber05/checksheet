    {
      "code": "WATR 4244",
      "subject": "WATR",
      "number": "4244",
      "level": 4000,
      "title": "Hydroinformatics",
      "credits": {
        "min": 3,
        "max": 3
      },
      "isVariableCredit": false,
      "description": "Analysis and examination of hydrologic data using basic statistics and computer programming. Calculation and interpretation of flow frequency and duration, hydrologic analysis of geospatial digital terrain data, and implementation and analysis of simple hydrologic models. Advanced methods of temporal and spatial hydrologic data visualization using computer programming.",
      "prerequisites": {
        "rawText": "FREC 3104 or WATR 3104 or FREC 1044",
        "referencedCourses": [
          "FREC 1044",
          "FREC 3104",
          "WATR 3104"
        ]
      },
