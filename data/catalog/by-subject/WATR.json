      "code": "WATR 3104",
      "subject": "WATR",
      "number": "3104",
      "level": 3000,
      "title": "Principles of Watershed Hydrology",
      "credits": {
        "min": 3,
        "max": 3
      },
      "isVariableCredit": false,
      "description": "Study of hydrology in watersheds. Qualitative and quantitative principles of physical hydrological processes governing the movement, storage, and transformation of water on the Earths surface as influenced by watershed characteristics, including human modifications. Pre: Junior Standing",
      "prerequisites": {
        "rawText": "MATH 1026 or MATH 1226 or STAT 3005 or STAT 3604 or STAT 3615",
        "referencedCourses": [
          "MATH 1026",
