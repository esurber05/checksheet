    {
      "code": "ITAL 3404",
      "subject": "ITAL",
      "number": "3404",
      "level": 3000,
      "title": "Topics in Italian Culture",
      "credits": {
        "min": 3,
        "max": 3
      },
      "isVariableCredit": false,
      "description": "Interdisciplinary study of Italian culture. Analysis of canonical and non-canonical cultural artifacts, including historical texts, narratives, poetry, drama, film, art, cuisine, and music. Interpretation of these artifacts within their historical, political, intellectual, and artistic contexts. Relationship of these artifacts to current events. Evaluation of advantages and challenges brought by globalization from an intercultural point of view. Taught in Italian. May be taken up to 3 times with different content for a maximum of 9 credit hours.",
      "prerequisites": {
        "rawText": "ITAL 2105 and ITAL 2106",
        "referencedCourses": [
          "ITAL 2105",
          "ITAL 2106"
        ]
      },
      "pathwaysConcepts": [],
      "contactHours": "(3 Lec, 3 Crd)",
      "crossListedWith": [],
      "repeatability": "Repeatability: up to 9 credit hours",
      "sourceUrl": "https://catalog.vt.edu/undergraduate/course-descriptions/ital/",
