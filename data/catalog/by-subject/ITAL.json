    {
      "code": "ITAL 2404",
      "subject": "ITAL",
      "number": "2404",
      "level": 2000,
      "title": "European Food Practices: You Are Where You Eat",
      "credits": {
        "min": 3,
        "max": 3
      },
      "isVariableCredit": false,
      "description": "Examination of cultures and cultural identity through the study of food in Western Europe, with a focus on critical and literary texts about culture and food practices in France, Italy, and Switzerland. Identification of challenges pertaining to sustainability, food supply, food waste, and consumption in local environments. Application of theoretical concepts discussed, including sustainability, terroir, gastronomy, slow food, authenticity, and how food shapes identities, to a field study experience that includes local interviews. Taught in English. Study Abroad offering at VT’s Steger Center in Riva San Vitale, Switzerland.",
      "pathwaysConcepts": [
        "2",
        "11"
      ],
      "contactHours": "(3 Lec, 3 Crd)",
      "crossListedWith": [],
      "sourceUrl": "https://catalog.vt.edu/undergraduate/course-descriptions/ital/",
      "catalogYear": "2025-2026"
